    def _get_data(self):
        to_import = OrderedDict()
        for key in self.raw_settings:
            try:
                to_import[key] = self.settings_vars[key].get()
            except ValueError:
                self.settings_widgets[key].configure(background='red')
                return None

        return to_import

    def check_change(self):
        new_cfg = self._get_data()
        if new_cfg is None:
            return False

        raw_settings = settings.export_to_odict()

        if new_cfg != raw_settings:
            for widget in self.settings_widgets.values():
                if isinstance(widget, Entry):
                    widget.configure(background='white')

            errors = self._validate_settings(new_cfg)
            if errors:
                for key in errors:
                    self.settings_widgets[key].configure(background='red')
                self.statusbar['text'] = "; ".join(
                    "{}: {}".format(key, reason) for key, reason in errors.items()
                )
                return False

            for k in raw_settings:
                if new_cfg[k] != raw_settings[k]:
                    logging.info(f"{k}, {raw_settings[k]}, {new_cfg[k]}")
            errors = settings.import_from_dict(new_cfg)
            if errors is None:
                if self.filename is not None:
                    self.play_button.configure(state=DISABLED)
                    self.conversion_stale = True
                    self.statusbar['text'] = "Settings changed; click Convert"
            else:
                # Mark wrong input fields appropriately.
                for e in errors:
                    self.settings_widgets[e].configure(background='red')
                self.statusbar['text'] = "Invalid setting: {}".format(", ".join(errors))
                return False
        return True

    def _validate_settings(self, values):
        errors = {}

        if values["pitchValue"] < 0:
            errors["pitchValue"] = "must be zero or greater"
        if not 0 <= values["unvoicedThreshold"] <= 1:
            errors["unvoicedThreshold"] = "must be between 0 and 1"
        if values["windowWidth"] < 1:
            errors["windowWidth"] = "must be at least 1"
        if not -1 <= values["preEmphasisAlpha"] <= 1:
            errors["preEmphasisAlpha"] = "must be between -1 and 1"
        if not -63 <= values["pitchOffset"] <= 63:
            errors["pitchOffset"] = "must be between -63 and 63"
        if values["minimumPitchInHZ"] <= 0:
            errors["minimumPitchInHZ"] = "must be greater than zero"
        if values["maximumPitchInHZ"] >= 4000:
            errors["maximumPitchInHZ"] = "must be below 4000"
        if values["maximumPitchInHZ"] <= values["minimumPitchInHZ"]:
            errors["maximumPitchInHZ"] = "must exceed minimumPitchInHZ"
        if not 0 <= values["subMultipleThreshold"] <= 1:
            errors["subMultipleThreshold"] = "must be between 0 and 1"
        if values["pitchDetector"] not in ("autocorrelation", "yin"):
            errors["pitchDetector"] = "must be autocorrelation or yin"
        if not 0 < values["yinThreshold"] < 1:
            errors["yinThreshold"] = "must be between 0 and 1"
        if values["lpcEstimator"] not in ("autocorrelation", "burg"):
            errors["lpcEstimator"] = "must be autocorrelation or burg"
        if not 0 <= values["rmsLimit"] <= 14:
            errors["rmsLimit"] = "must be between 0 and 14"
        if values["outputFormat"] not in ("arduino", "C", "hex", "python"):
            errors["outputFormat"] = "must be arduino, C, hex, or python"
        if values["tablesVariant"] not in ("tms5100", "tms5110a", "tms5200", "tms5220", "Talkie"):
            errors["tablesVariant"] = "unsupported table"

        if values["minimumPitchInHZ"] > 0:
            maximum_period = math.floor(8000 / values["minimumPitchInHZ"] + 1)
            minimum_frame_rate = math.ceil((maximum_period + 2) / 16)
            if values["frameRate"] < minimum_frame_rate:
                errors["frameRate"] = "must be at least {} ms for this pitch range".format(minimum_frame_rate)

        return errors

