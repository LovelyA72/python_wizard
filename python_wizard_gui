    def quit(self):
        if self.conversion_process is not None and self.conversion_process.is_alive():
            self.conversion_process.terminate()
            self.conversion_process.join(timeout=1)
        for process in self.finished_conversion_processes:
            if process.is_alive():
                process.terminate()
            process.join(timeout=1)
        self.master.quit()

    def _file_open(self):
        if self.conversion_active:
            messagebox.showinfo("Conversion running", "Wait for the current conversion to finish.")
            return
        self.filename = filedialog.askopenfilename(parent=self.master,filetypes=[('Waves',"*.wav")])
        if self.filename:
            self.processor = None
            self.optimization_result = None
            self.initial_quantized_frames = None
            self.initial_synthesis = None
            self.optimized_synthesis = None
            self.frames = []
            self.play_button.configure(state=DISABLED)
            self.convert_button.configure(state=NORMAL)
            self.conversion_stale = True
            self.statusbar['text'] = "WAV loaded; click Convert"

    def _file_export_lpc(self):
        if self.processor is None or self.conversion_stale:
            messagebox.showinfo("Nothing to export", "Open a WAV file and convert it first.")
            return

        basename = os.path.splitext(os.path.basename(self.filename))[0] + ".lpc"
        filename = filedialog.asksaveasfilename(
            parent=self.master,
            title="Export LPC",
            defaultextension=".lpc",
            initialdir=os.path.dirname(self.filename),
            initialfile=basename,
            filetypes=[("LPC byte stream", "*.lpc"), ("All files", "*.*")],
        )
        if not filename:
            return

        try:
            byte_count = BitPacker.write_lpc(self.processor, filename)
        except OSError as error:
            messagebox.showerror("Export failed", str(error))
            self.statusbar['text'] = "LPC export failed"
            return

        self.statusbar['text'] = "Exported {} LPC bytes to {}".format(byte_count, filename)

    def _save_synthesis(self, optimized):
        audio = self.optimized_synthesis if optimized else self.initial_synthesis
        if audio is None:
            messagebox.showinfo("Nothing to export", "Enable optimization and convert a WAV first.")
            return
        suffix = "optimized" if optimized else "initial"
        filename = filedialog.asksaveasfilename(
            parent=self.master, title="Export {} synthesis".format(suffix),
            defaultextension=".wav", initialdir=os.path.dirname(self.filename),
            initialfile="{}_{}.wav".format(os.path.splitext(os.path.basename(self.filename))[0], suffix),
            filetypes=[("Wave audio", "*.wav"), ("All files", "*.*")],
        )
        if filename:
            from pywizard.FrameOptimizer import write_synthesized_wav
            write_synthesized_wav(filename, audio)
            self.statusbar['text'] = "Exported {} synthesis to {}".format(suffix, filename)

    def _file_export_optimization_report(self):
        if self.optimization_result is None:
            messagebox.showinfo("Nothing to export", "Enable optimization and convert a WAV first.")
            return
        filename = filedialog.asksaveasfilename(
            parent=self.master, title="Export optimization report",
            defaultextension=".json", initialdir=os.path.dirname(self.filename),
            initialfile="optimization_report.json",
            filetypes=[("JSON report", "*.json"), ("All files", "*.*")],
        )
        if filename:
            from pywizard.FrameOptimizer import write_report
            write_report(filename, self.optimization_result)
            self.statusbar['text'] = "Exported optimization report to {}".format(filename)

    def _file_export_optimization_parameters(self):
        if self.optimization_result is None:
            messagebox.showinfo("Nothing to export", "Enable optimization and convert a WAV first.")
            return
        filename = filedialog.asksaveasfilename(
            parent=self.master, title="Export optimized frame parameters",
            defaultextension=".json", initialdir=os.path.dirname(self.filename),
            initialfile="optimized_frames.json",
            filetypes=[("JSON parameters", "*.json"), ("All files", "*.*")],
        )
        if filename:
            with open(filename, "w", encoding="utf-8") as output_file:
                json.dump([frame.as_dict() for frame in self.optimization_result.frames], output_file, indent=2)
            self.statusbar['text'] = "Exported optimized parameters to {}".format(filename)


