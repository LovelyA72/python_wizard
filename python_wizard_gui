    def _make_scroll_pos(self):
        frame_count = float(len(self.frames))
        # First line of scrolled data
        scroll_offset = self.first_line / (frame_count+self.NUM_ROWS)
        page_size = float(self.NUM_ROWS) / (frame_count+self.NUM_ROWS)

        top = scroll_offset
        bottom = scroll_offset + page_size

        # Clip to bottom
        if bottom > 1:
            top = 1 - page_size
            bottom = 1

        return (top, bottom)

    def _scrolled(self, cmd, value, opt=None):
        frame_count = float(len(self.frames))
        logging.debug("cmd={}, value={}, opt={}, frame_count={}".format(cmd, value, opt, frame_count))
        page_size = float(self.NUM_ROWS) / frame_count

        if cmd == SCROLL:
            if opt == "units":
                self.first_line += int(value)
            if opt == "pages":
                self.first_line += int(self.NUM_ROWS * int(value))
        elif cmd == MOVETO:
            self.first_line = int( (float(value)) * frame_count - self.NUM_ROWS / 2)
            if self.first_line < 0:
                self.first_line = 0
            elif self.first_line+self.NUM_ROWS > frame_count:
                self.first_line = frame_count - self.NUM_ROWS

        self.first_line = max(0, self.first_line)
        self.first_line = int(min(frame_count-self.NUM_ROWS, self.first_line))

        self.table_scrollbar.set( *self._make_scroll_pos() )

        #self.first_line = int(self.table_scrollbar.get()[0] * frame_count)
        self._update_table()


    def _table_iterator(self, frames):
        if frames is not None:
            self.frames = frames
        else:
            frames = self.frames

        if len(frames)==0:
            return []

        scroll_offset = self.first_line / float(self.NUM_ROWS)

        l = min( ( self.first_line+self.NUM_ROWS, len(frames) ) )

        page_size = float(self.NUM_ROWS) / len(frames)

        scroll_pos = self.first_line * page_size

        self.table_scrollbar.set(scroll_offset, scroll_offset+page_size )

        return zip(range(0, self.NUM_ROWS), range(self.first_line,l), frames[self.first_line:l])

    def _update_table(self, frames = None):
        prev=0
        parameters = self.codingTable.parameters()
        for (line, n, frame) in self._table_iterator(frames):
            params = frame.parameters()
            self.table_labels[line].set( str(n) )
            for p in parameters:
                self.table_vars[(line, p)].set(0)
            for p in params:
                self.table_vars[ (line, p) ].set(params[p])
            if (line-1, 'size') in self.table_vars:
                prev=self.table_vars[(line-1, 'size')].get()
            self.table_vars[(line, 'size')].set(prev+15)
            
    def _readback_table(self, frames = None):
        for (line, n, frame) in self._table_iterator(frames):
            params = frame.parameters()
            self.table_labels[line].set( str(n) )
            changed = False
            for p in params:
                value = self.table_vars[ (line, p) ].get()
                changed = changed or not ( int(params[p]) == int(value) )
                if not (int(params[p]) == int(value)):
                    print(p, value)
                params[p] = int(value)
            if changed:
                self._update_output()

    @staticmethod
    def _progress_bar(current, total, label, width=24):
        """Format a compact ASCII progress bar for the status label."""
        fraction = 0.0 if total <= 0 else max(0.0, min(1.0, current / total))
        filled = int(round(width * fraction))
        return "[{}{}] {:3.0f}% {}".format(
            "#" * filled, "-" * (width - filled), fraction * 100, label,
        )

    def _set_conversion_controls(self, enabled):
        state = NORMAL if enabled else DISABLED
        for key, widget in self.settings_widgets.items():
            widget.configure(state="readonly" if enabled and key in SELECTOR_CHOICES else state)
        for widget in self.optimizer_widgets:
            if enabled and isinstance(widget, Combobox):
                widget.configure(state="readonly")
            else:
                widget.configure(state=state)
        self.convert_button.configure(
            state=NORMAL if enabled and self.filename is not None else DISABLED
        )

    def _start_conversion(self):
        if self.conversion_active:
            return
        if not self.filename:
            messagebox.showinfo("Nothing to convert", "Open a WAV file first.")
            return
        if not self.check_change():
            return

        self.conversion_active = True
        self.conversion_stale = True
        self.play_button.configure(state=DISABLED)
        self._set_conversion_controls(False)
        self.statusbar['text'] = self._progress_bar(0, 1, "Analyzing WAV…")
        self.optimization_result = None
        self.initial_quantized_frames = None
        self.initial_synthesis = None
        self.optimized_synthesis = None

        from pywizard.GuiConversion import run_conversion_process

        optimizer_values = {
            "enabled": bool(self.optimize_enabled.get()),
            "passes": int(self.optimize_passes.get()),
            "radius": int(self.optimize_radius.get()),
            "lookahead": int(self.optimize_lookahead.get()),
            "loss_profile": self.optimize_loss_profile.get(),
            "input_frame_samples": max(1, int(round(8 * settings.frameRate))),
        }
        self.conversion_events = self.mp_context.Queue()
        self.conversion_process = self.mp_context.Process(
            target=run_conversion_process,
            args=(
                self.conversion_events, self.filename,
                dict(settings.export_to_odict()), optimizer_values,
            ),
            daemon=True,
        )
        self.conversion_process.start()

    def _finish_conversion_process(self):
        if self.conversion_process is not None:
            self.conversion_process.join(timeout=0)
            if self.conversion_process.is_alive():
                self.finished_conversion_processes.append(self.conversion_process)
            else:
                self.conversion_process.close()
            self.conversion_process = None
        if self.conversion_events is not None:
            self.conversion_events.close()
            self.conversion_events = None

    def _reap_conversion_processes(self):
        remaining = []
        for process in self.finished_conversion_processes:
            process.join(timeout=0)
            if process.is_alive():
                remaining.append(process)
            else:
                process.close()
        self.finished_conversion_processes = remaining

    def _handle_conversion_events(self):
        if self.conversion_events is None:
            return
        while True:
            try:
                event, value = self.conversion_events.get_nowait()
            except queue.Empty:
                break
            if event == "progress":
                current, total = value
                self.statusbar['text'] = self._progress_bar(
                    current, total, "Optimizing frames…"
                )
                continue

            self.conversion_active = False
            self._set_conversion_controls(True)
            self._finish_conversion_process()
            if event == "error":
                self.processor = None
                self.frames = []
                self.conversion_stale = True
                self.play_button.configure(state=DISABLED)
                self.statusbar['text'] = "Conversion failed"
                messagebox.showerror("Conversion failed", value)
                return

            (
                self.processor, chip_variant, self.optimization_result,
                self.initial_quantized_frames, self.initial_synthesis,
                self.optimized_synthesis,
            ) = value
            self.codingTable = CodingTable(chip_variant)
            self.conversion_stale = False
            self._update_table(self.processor.frames)
            self._update_output()
            if not self.playback_active:
                self.play_button.configure(state=NORMAL)
            if self.optimization_result is None:
                self.statusbar['text'] = self._progress_bar(1, 1, "Conversion complete")
            else:
                result = self.optimization_result
                self.statusbar['text'] = self._progress_bar(1, 1, (
                    "{} of {} changed; loss {:.4f} → {:.4f} ({:.2f}%), {:.2f}s"
                ).format(
                    result.changed_frames, len(result.frames), result.initial_loss,
                    result.optimized_loss, result.improvement_percent,
                    result.elapsed_seconds,
                ))
            return

    def _repeatedly(self):
        self.root.after(100, self._repeatedly)
        self._handle_playback_events()
        self._handle_conversion_events()
        self._reap_conversion_processes()
        if self.processor is not None and not self.conversion_active:
            self._readback_table()

    def _update_output(self):
            result = BitPacker.pack(self.processor)
            self.output_text.delete(1.0, END)
            self.output_text.insert(END, result)

    def play(self):
        if self.processor is None or self.conversion_stale:
            messagebox.showinfo("Nothing to play", "Open a WAV file and convert it first.")
            return
        if pyaudio is None:
            messagebox.showerror(
                "Playback unavailable",
                "PyAudio is required for playback. Install it with: python -m pip install pyaudio",
            )
            return

        encoded_frames = BitPacker.raw_stream(self.processor)
        self.statusbar['text'] = "Playing {} LPC bytes…".format(len(encoded_frames))
        self.playback_active = True
        self.play_button.configure(state=DISABLED)
        chip_variant = settings.tablesVariant
        threading.Thread(
            target=self._play_audio,
            args=(encoded_frames, chip_variant),
            daemon=True,
        ).start()

    def _play_audio(self, encoded_frames, chip_variant):
        audio = None
        stream = None
        try:
            from lpcplayer import player, tables
            if chip_variant.lower() == "talkie":
                from pywizard.TalkieSynthesizer import TalkieSynthesizer
                decoder = TalkieSynthesizer()
            else:
                decoder = player.LpcDecoder(tables.tables[chip_variant])
            samples = decoder.decode(encoded_frames)

            audio = pyaudio.PyAudio()
            stream = audio.open(format=pyaudio.paUInt8, channels=1, rate=8000, output=True)
            stream.write(bytes(samples))
            self.playback_events.put(("played", len(encoded_frames)))
        except Exception as error:
            self.playback_events.put(("error", str(error)))
        finally:
            if stream is not None:
                stream.stop_stream()
                stream.close()
            if audio is not None:
                audio.terminate()

    def _handle_playback_events(self):
        while not self.playback_events.empty():
            event, value = self.playback_events.get()
            self.playback_active = False
            self.play_button.configure(state=NORMAL)
            if event == "played":
                self.statusbar['text'] = "Played {} LPC bytes".format(value)
            else:
                self.statusbar['text'] = "Playback failed"
                messagebox.showerror("Playback failed", value)

    def mainloop(self):
        self.root.after(500, self._repeatedly)
        self.master.mainloop()

def main():
    settings.outputFormat = 'python'
    settings.tablesVariant = 'tms5100'
    logging.basicConfig(level=logging.INFO)
    root = Tk()
    gui = Gui(root)
    gui.mainloop()


if __name__ == "__main__":
    main()
