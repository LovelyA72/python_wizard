def optimize_processor_for_gui(
    processor, original_pcm, chip_variant, passes, radius, lookahead, loss_profile,
    input_frame_samples, progress_callback=None,
):
    """Compatibility wrapper around the process-safe GUI optimizer helper."""
    from pywizard.GuiConversion import optimize_processor
    return optimize_processor(
        processor, original_pcm, chip_variant, passes, radius, lookahead,
        loss_profile, input_frame_samples, progress_callback,
    )

