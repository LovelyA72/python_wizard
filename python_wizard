#!/usr/bin/env python3
import logging
import re
import os
import sys
import json
from collections import Counter
from lpcplayer.tables import tables

'''
Command line application for processing WAV files into LPC data
for use with TMS5220 (emulators)
'''

import argparse
parser = argparse.ArgumentParser()
parser.add_argument("-u", "--unvoicedThreshold",
    help="Unvoiced frame threshold",
    action="store",
    default=0.3,
    type=float)
parser.add_argument("-w", "--windowWidth",
    help="Window width in frames",
    action="store",
    default=2,
    type=int)
parser.add_argument("-U", "--normalizeUnvoicedRMS",
    help="Normalize unvoiced frame RMS",
    action="store_true")
parser.add_argument("-V", "--normalizeVoicedRMS",
    help="Normalize voiced frame RMS",
    action="store_true")
parser.add_argument("-S", "--includeExplicitStopFrame",
    help="Create explicit stop frame (needed e.g. for Talkie)",
    action="store_true")
parser.add_argument("-p", "--preEmphasis",
    help="Pre emphasize sound to improve quality of translation",
    action="store_true")
parser.add_argument("-a", "--preEmphasisAlpha",
    help="Emphasis coefficient",
    type=float,
    default=-0.9373)
parser.add_argument("-d", "--debug",
    help="Enable (lots) of debug output",
    action="store_true")
parser.add_argument("-r", "--pitchRange",
    help="Comma separated range of available voice pitch in Hz. Default: 50,500",
    default="50,500")
parser.add_argument("-F", "--frameRate",
    default=25,
    type=int)
parser.add_argument("-m", "--subMultipleThreshold",
    help="Autocorrelation sub-multiple threshold",
    default=0.9,
    type=float)
parser.add_argument("--pitchDetector",
    help="Pitch detection algorithm",
    choices=["autocorrelation", "yin"],
    default="autocorrelation")
parser.add_argument("--yinThreshold",
    help="YIN trough threshold",
    default=0.1,
    type=float)
parser.add_argument("--lpcEstimator",
    help="LPC coefficient estimation algorithm",
    choices=["autocorrelation", "burg"],
    default="autocorrelation")
parser.add_argument("-f", "--outputFormat",
    help="Output file format",
    choices=["arduino", "C", "hex", "python", "lpc"],
    default="hex")
parser.add_argument("-o", "--output",
    help="Write output to this file (defaults to the WAV name with .lpc for LPC output)")
parser.add_argument("-T", "--tablesVariant",
    help="Tables variant",
    choices=("tms5100", "tms5110a", "tms5200", "tms5220", "Talkie"),
    default="tms5220")
parser.add_argument("--talkieMitigationStrength",
    help="Talkie burst mitigation strength from 0 (off) to 3 (default: 1)",
    default=1.0,
    type=float)
parser.add_argument("--talkieGateThreshold",
    help="Talkie three-frame RMS gate threshold from 0 (off) to 1 (default: 0)",
    default=0.0,
    type=float)
parser.add_argument("--optimize", action="store_true",
    help="Optimize quantized frames using analysis-by-synthesis")
parser.add_argument("--optimize-passes", default=2, type=int,
    help="Maximum coordinate-descent passes (default: 2)")
parser.add_argument("--optimize-radius", default=1, type=int,
    help="Neighboring table-index radius (default: 1)")
parser.add_argument("--optimize-lookahead", default=1, type=int,
    help="25-sample boundary blocks included from the next frame")
parser.add_argument("--optimize-loss-profile", choices=["waveform", "spectral", "balanced"],
    default="balanced", help="Optimization loss weighting (default: balanced)")
parser.add_argument("--optimize-report", metavar="PATH",
    help="Write a per-frame optimization report as JSON")
parser.add_argument("--optimize-initial-wav", metavar="PATH",
    help="Export synthesis of the initial quantized frames")
parser.add_argument("--optimize-optimized-wav", metavar="PATH",
    help="Export synthesis of the optimized quantized frames")
parser.add_argument("--optimize-parameters", metavar="PATH",
    help="Export final indexed frame parameters as JSON")

parser.add_argument("filename",
    help="File name of a .wav file to be processed",
    action="store")

args = parser.parse_args()

if not 0 <= args.talkieMitigationStrength <= 3:
    parser.error("--talkieMitigationStrength must be between 0 and 3")
if not 0 <= args.talkieGateThreshold <= 1:
    parser.error("--talkieGateThreshold must be between 0 and 1")

if args.debug:
    logging.basicConfig(level=logging.DEBUG)

from pywizard.userSettings import settings
settings.import_from_argparse(args)

from pywizard.FrameDataBinaryEncoder import BitPacker
from pywizard.Processor import Processor
from pywizard.Buffer import Buffer
#settings.import_from_argparse(args)
from pywizard.CodingTable import CodingTable

b=Buffer.fromWave(args.filename)
if b is None:
    sys.exit()
original_pcm = b.samples.copy()

x=Processor(b, args.tablesVariant)

talkie_config = None
if args.tablesVariant.lower() == "talkie":
    from pywizard.QuantizedFrame import QuantizedFrame
    from pywizard.TalkieMitigator import (
        TalkieMitigationConfig, mitigate_talkie_frames,
    )
    talkie_config = TalkieMitigationConfig(
        strength=args.talkieMitigationStrength,
        gate_threshold=args.talkieGateThreshold,
        input_frame_samples=max(1, int(round(8 * args.frameRate))),
    )
    talkie_mitigation = mitigate_talkie_frames(
        [QuantizedFrame.from_frame(frame) for frame in x.frames],
        original_pcm,
        talkie_config,
    )
    x.frames = talkie_mitigation.frames
    if talkie_mitigation.changed_frames:
        print(
            "Talkie processing: adjusted {} frame{} ({} gated) in {:.3f}s".format(
                talkie_mitigation.changed_frames,
                "" if talkie_mitigation.changed_frames == 1 else "s",
                talkie_mitigation.gated_frames,
                talkie_mitigation.elapsed_seconds,
            ),
            file=sys.stderr,
        )

if args.optimize:
    from pywizard.FrameOptimizer import (
        OptimizationConfig, optimize_frames, write_report, write_synthesized_wav,
    )
    from pywizard.QuantizedFrame import QuantizedFrame
    from pywizard.TmsSynthesizer import TmsSynthesizer
    from pywizard.TalkieSynthesizer import TalkieSynthesizer

    initial_frames = [QuantizedFrame.from_frame(frame) for frame in x.frames]
    config = OptimizationConfig(
        passes=max(0, args.optimize_passes),
        radius=max(0, args.optimize_radius),
        lookahead=max(0, args.optimize_lookahead),
        loss_profile=args.optimize_loss_profile,
        input_frame_samples=max(1, int(round(8 * args.frameRate))),
    )
    result = optimize_frames(initial_frames, original_pcm, tables[args.tablesVariant], config)
    x.frames = result.frames
    if talkie_config is not None:
        talkie_mitigation = mitigate_talkie_frames(
            result.frames,
            original_pcm,
            talkie_config,
        )
        x.frames = talkie_mitigation.frames
        result.frames = x.frames
    preview_synth = (
        TalkieSynthesizer()
        if args.tablesVariant.lower() == "talkie"
        else TmsSynthesizer(tables[args.tablesVariant])
    )
    initial_audio = preview_synth.synthesize(initial_frames)
    optimized_audio = preview_synth.synthesize(x.frames)
    if args.optimize_initial_wav:
        write_synthesized_wav(args.optimize_initial_wav, initial_audio)
    if args.optimize_optimized_wav:
        write_synthesized_wav(args.optimize_optimized_wav, optimized_audio)
    if args.optimize_report:
        write_report(args.optimize_report, result)
    if args.optimize_parameters:
        with open(args.optimize_parameters, "w", encoding="utf-8") as parameter_file:
            json.dump([frame.as_dict() for frame in result.frames], parameter_file, indent=2)
    counts = Counter(p for change in result.changes for p in change["parameters_changed"])
    print(
        "Optimization: {} frames, {} changed, loss {:.6f} -> {:.6f} "
        "({:.2f}% improvement), {:.2f}s, {} candidate evaluations".format(
            len(initial_frames), result.changed_frames, result.initial_loss,
            result.optimized_loss, result.improvement_percent,
            result.elapsed_seconds, result.candidate_evaluations,
        ), file=sys.stderr,
    )
    if counts:
        print("Most changed parameters: " + ", ".join(
            "{}={}".format(name, count) for name, count in counts.most_common()
        ), file=sys.stderr)

new_varname = os.path.basename(args.filename)
new_varname = os.path.splitext(new_varname)[0]

if re.match("^[^A-Za-z_]", new_varname):
    new_varname = "_"+new_varname

if args.outputFormat == "lpc":
    output_filename = args.output
    if output_filename is None:
        output_filename = os.path.splitext(args.filename)[0] + ".lpc"
    try:
        byte_count = BitPacker.write_lpc(x, output_filename)
    except OSError as error:
        parser.error("could not write {}: {}".format(output_filename, error))
    print("Wrote {} LPC bytes to {}".format(byte_count, output_filename))
else:
    result = BitPacker.pack(x).replace("FILENAME", new_varname)
    if args.output is None:
        print(result)
    else:
        try:
            with open(args.output, "w", encoding="utf-8") as output_file:
                print(result, file=output_file)
        except OSError as error:
            parser.error("could not write {}: {}".format(args.output, error))
        print("Wrote {} output to {}".format(args.outputFormat, args.output))
